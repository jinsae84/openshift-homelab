$TTL 1W
@       IN SOA  bastion.ocp.lab. root.ocp.lab. (
                        2026052702 ; serial
                        3H         ; refresh
                        30M        ; retry
                        2W         ; expiry
                        1W )       ; minimum

        IN NS   bastion.ocp.lab.

bastion                IN A    192.168.0.17

api.paas               IN A    192.168.0.17
api-int.paas           IN A    192.168.0.17

*.apps.paas            IN A    192.168.0.17

master0.paas                IN A    192.168.0.20
master1.paas                IN A    192.168.0.21
master2.paas                IN A    192.168.0.22

worker0.paas                IN A    192.168.0.23
worker1.paas                IN A    192.168.0.24
